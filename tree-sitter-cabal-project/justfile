default: test

# Run tests for this grammar
test: parse-corpus parse-corpus-hls
    tree-sitter test

# Parse every cabal.project / *.project file in the cabal repository.
parse-corpus:
    ../test/parse-cabal-project.sh "$CABAL_SRC"

# Parse every cabal.project / *.project file in the haskell-language-server
# repository.
parse-corpus-hls:
    ../test/parse-cabal-project.sh "$HLS_SRC"

# Build the grammar via the nix flake (buildGrammar runs generate internally).
build:
    nix build ..#tree-sitter-cabal-project
    tree-sitter generate

# Check grammar for errors
check:
    nix build ..#tree-sitter-cabal-project --no-link

# Format the grammar file (mode: write|check)
fmt mode="write":
    prettier --{{ mode }} grammar.js

# Clean build artifacts
clean:
    rm -rf cabal-project.so result

# Parse a file and print AST
parse file:
    tree-sitter parse {{ file }}

# Show syntax highlighting for a file
highlight file:
    tree-sitter highlight {{ file }}
