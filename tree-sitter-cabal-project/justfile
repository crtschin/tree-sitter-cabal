default: test

# Run tests for this grammar
test:
    tree-sitter test
    node --test test/*_test.js

# Generate C parser from grammar.js and build shared library
build:
    tree-sitter generate
    tree-sitter build

# Check grammar for errors
check:
    tree-sitter generate

# Format the grammar file and JS test files (mode: write|check)
fmt mode="write":
    prettier --{{ mode }} grammar.js 'test/*.js'

# Clean build artifacts
clean:
    rm -rf build/Release/*.node cabal-project.so
    make clean

# Open the interactive playground (requires WASM build)
playground:
    tree-sitter build --wasm
    tree-sitter playground

# Parse a file and print AST
parse file:
    tree-sitter parse {{ file }}

# Show syntax highlighting for a file
highlight file:
    tree-sitter highlight {{ file }}
