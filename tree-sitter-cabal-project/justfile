default: test

# Run tests for this grammar
test: parse-corpus
    tree-sitter test

# Parse every cabal.project / *.project file across the configured corpora.
parse-corpus:
    ../test/parse-corpus.sh cabal-project | tapview

# Build the grammar via the nix flake (buildGrammar runs generate internally).
build:
    nix build ..#tree-sitter-cabal-project
    tree-sitter generate

# Check grammar for errors
check:
    nix build ..#tree-sitter-cabal-project --no-link

# Format the grammar file (mode: write|check)
fmt mode="write":
    prettier --{{ mode }} grammar.js

# Clean build artifacts
clean:
    rm -rf cabal-project.so result

# Parse a file and print AST
parse file:
    tree-sitter parse {{ file }}

# Show syntax highlighting for a file
highlight file:
    tree-sitter highlight {{ file }}

# Profile parsing the cabal-project corpus and emit flamegraph-cabal-project.svg at the repo root.
flamegraph:
    ../test/flamegraph-corpus.sh cabal-project ../flamegraph-cabal-project.svg

# Benchmark parsing the cabal-project corpus with hyperfine.
bench:
    ../test/bench-corpus.sh cabal-project
