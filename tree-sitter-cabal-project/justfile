default: test

# Run tests for this grammar
test: parse-corpus
    tree-sitter test

# Parse every cabal.project / *.project file in the cabal submodule and
# fail if any has an ERROR node.
parse-corpus:
    set -o pipefail; ../test/parse-corpus.sh \
        --root "$CABAL_SRC" \
        --include '*.project' \
        --include 'cabal.project.*' \
        --exclude '*.hs' \
        --exclude '*.out' \
        --exclude '*.lock' \
        --deny 'cabal-testsuite/PackageTests/ProjectConfig/FieldStanzaConfusion/cabal.project' \
        | tapview

# Generate C parser from grammar.js and build shared library
build:
    tree-sitter generate
    tree-sitter build

# Check grammar for errors
check:
    tree-sitter generate

# Format the grammar file (mode: write|check)
fmt mode="write":
    prettier --{{ mode }} grammar.js

# Clean build artifacts
clean:
    rm -rf cabal-project.so

# Parse a file and print AST
parse file:
    tree-sitter parse {{ file }}

# Show syntax highlighting for a file
highlight file:
    tree-sitter highlight {{ file }}
