Rec {
Bindings.$wgo [InlPrag=[2], Occ=LoopBreaker]
  :: GHC.Prim.Int# -> [GHC.Types.Int] -> GHC.Prim.Int#
[GblId[StrictWorker([~, !])],
 Arity=2,
 Str=<L><1L>,
 Unf=OtherCon []] =
    {} \r [ww ds]
        case ds<TagProper> of wild {
          [] -> ww<TagProper>;
          : x [Occ=Once1!] xs [Occ=Once1] ->
              case x of wild1 {
              GHC.Types.I# y [Occ=Once1] ->
              case +# [ww y] of sat {
              __DEFAULT ->
              case xs of xs [Occ=Once1] { __DEFAULT -> Bindings.$wgo sat xs; };
              };
              };
        };
end Rec }

