Bindings.$wlabel [InlPrag=[2]]
  :: GHC.Internal.Data.Either.Either GHC.Types.Int GHC.Types.Int
     -> GHC.Prim.Int#
[GblId[StrictWorker([!])], Arity=1, Str=<1L>, Unf=OtherCon []] =
    {} \r [e]
        case e<TagProper> of wild {
          GHC.Internal.Data.Either.Left n [Occ=Once1!] ->
              case n of wild1 {
              GHC.Types.I# x [Occ=Once1] ->
              case +# [x 1#] of x1 {
              __DEFAULT ->
              case ># [1# x1] of lwild {
                __DEFAULT ->
                    let-no-escape {
                      exit [Occ=OnceL1!T[1], Dmd=SC(S,L)]
                        :: GHC.Prim.Int# -> GHC.Prim.Int#
                      [LclId[JoinId(1)(Nothing)], Arity=1, Str=<L>, Unf=OtherCon []] =
                          {x1} \r [ww] case +# [x1 ww] of sat { __DEFAULT -> +# [1# sat]; };
                    } in 
                      let-no-escape {
                        Rec {
                        $wgo3 [InlPrag=[2], Occ=LoopBreakerT[2], Dmd=SC(S,C(1,L))]
                          :: GHC.Prim.Int# -> GHC.Prim.Int# -> GHC.Prim.Int#
                        [LclId[JoinId(2)(Nothing)], Arity=2, Str=<L><L>, Unf=OtherCon []] =
                            {$wgo3, exit, x1} \r [x2 ww]
                                case ==# [x2 x1] of lwild1 {
                                  __DEFAULT ->
                                      case +# [ww 1#] of sat {
                                      __DEFAULT ->
                                      case +# [x2 1#] of sat { __DEFAULT -> $wgo3 sat sat; };
                                      };
                                  1# -> exit ww;
                                };
                        end Rec }
                      } in  $wgo3 1# 0#;
                1# -> x1<TagProper>;
              };
              };
              };
          GHC.Internal.Data.Either.Right n [Occ=Once1!] ->
              case n of wild1 {
              GHC.Types.I# x [Occ=Once1] ->
              case *# [x 2#] of x1 {
              __DEFAULT ->
              case ># [1# x1] of lwild {
                __DEFAULT ->
                    let-no-escape {
                      exit [Occ=OnceL1!T[1], Dmd=SC(S,L)]
                        :: GHC.Prim.Int# -> GHC.Prim.Int#
                      [LclId[JoinId(1)(Nothing)], Arity=1, Str=<L>, Unf=OtherCon []] =
                          {x1} \r [ww] case +# [x1 ww] of sat { __DEFAULT -> +# [1# sat]; };
                    } in 
                      let-no-escape {
                        Rec {
                        $wgo3 [InlPrag=[2], Occ=LoopBreakerT[2], Dmd=SC(S,C(1,L))]
                          :: GHC.Prim.Int# -> GHC.Prim.Int# -> GHC.Prim.Int#
                        [LclId[JoinId(2)(Nothing)], Arity=2, Str=<L><L>, Unf=OtherCon []] =
                            {$wgo3, exit, x1} \r [x2 ww]
                                case ==# [x2 x1] of lwild1 {
                                  __DEFAULT ->
                                      case +# [ww 1#] of sat {
                                      __DEFAULT ->
                                      case +# [x2 1#] of sat { __DEFAULT -> $wgo3 sat sat; };
                                      };
                                  1# -> exit ww;
                                };
                        end Rec }
                      } in  $wgo3 1# 0#;
                1# -> x1<TagProper>;
              };
              };
              };
        };

